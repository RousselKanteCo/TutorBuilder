function toggleSubEditor() {
  const on  = getSwState('subtitles-sw');
  document.getElementById('sub-editor-wrap').classList.toggle('disabled', !on);
}

// ═══════════════════════════════════════════════════════
//  SOUS-TITRES CANVAS
// ═══════════════════════════════════════════════════════
const SUB_PRESETS = [
  {name:"Moderne",  size:48,color:"#ffffff",font:"calibri",ow:1,oc:"#000000",bg:true, bgc:"#000000",bga:75,br:10,sh:true, sha:60,pos:"bottom",mg:60},
  {name:"Classique",size:48,color:"#ffffff",font:"arial",  ow:3,oc:"#000000",bg:false,bgc:"#000000",bga:0, br:0, sh:false,sha:0, pos:"bottom",mg:60},
  {name:"Netflix",  size:52,color:"#ffff00",font:"arial",  ow:4,oc:"#000000",bg:false,bgc:"#000000",bga:0, br:0, sh:false,sha:0, pos:"bottom",mg:60},
  {name:"Cinéma",   size:44,color:"#f5f5dc",font:"georgia",ow:2,oc:"#2c1810",bg:false,bgc:"#000000",bga:0, br:0, sh:true, sha:70,pos:"center",mg:60},
  {name:"Social",   size:44,color:"#ffffff",font:"calibri",ow:0,oc:"#000000",bg:true, bgc:"#000000",bga:90,br:20,sh:false,sha:0, pos:"bottom",mg:60},
  {name:"Néon",     size:44,color:"#00ffc8",font:"calibri",ow:2,oc:"#00a080",bg:true, bgc:"#000000",bga:80,br:8, sh:true, sha:50,pos:"bottom",mg:60},
];
let selPreset = 0;

function hexToRgb(hex, a) {
  const h=hex.replace('#','');
  return `rgba(${parseInt(h.slice(0,2),16)},${parseInt(h.slice(2,4),16)},${parseInt(h.slice(4,6),16)},${a})`;
}
function getSwState(id){return document.getElementById(id).classList.contains('on')}
function toggleSw(id){document.getElementById(id).classList.toggle('on')}
function syncVal(r,v,u){document.getElementById(v).textContent=document.getElementById(r).value+u}

function getSubStyle(){
  return{
    enabled:        getSwState('subtitles-sw'),
    style_preset:   SUB_PRESETS[selPreset].name.toLowerCase().replace(/é/g,'e'),
    font_size:      parseInt(document.getElementById('s-size').value),
    font_family:    document.getElementById('s-font').value,
    text_color:     document.getElementById('s-color').value.replace('#','').toUpperCase(),
    outline_width:  parseInt(document.getElementById('s-ow').value),
    outline_color:  document.getElementById('s-oc').value.replace('#','').toUpperCase(),
    bg_enabled:     getSwState('s-bg-sw'),
    bg_color:       document.getElementById('s-bgc').value.replace('#','').toUpperCase(),
    bg_opacity:     parseInt(document.getElementById('s-bga').value),
    bg_radius:      parseInt(document.getElementById('s-br').value),
    shadow:         getSwState('s-sh-sw'),
    shadow_opacity: parseInt(document.getElementById('s-sha').value),
    position:       document.getElementById('s-pos').value,
    margin:         parseInt(document.getElementById('s-mg').value),
  };
}

function drawSubPreview(){
  const canvas=document.getElementById('sub-canvas');
  const wrap=canvas.parentElement;
  const W=wrap.offsetWidth||220, H=Math.round(W*9/16);
  canvas.width=W; canvas.height=H;
  const ctx=canvas.getContext('2d');
  ctx.fillStyle='#0a0a12'; ctx.fillRect(0,0,W,H);
  ctx.fillStyle='rgba(255,255,255,.04)';
  ctx.fillRect(10,12,W*0.5,5); ctx.fillRect(10,22,W*0.3,4);
  ctx.fillStyle='rgba(59,130,246,.06)'; ctx.fillRect(10,35,W*0.7,H*0.3);
  const text=document.getElementById('sub-preview-text').value||'Aperçu sous-titre';
  const sz=document.getElementById('s-size').value;
  const fsize=Math.max(10,Math.round(sz*W/640));
  const font=document.getElementById('s-font').value;
  const color=document.getElementById('s-color').value;
  const ow=parseInt(document.getElementById('s-ow').value);
  const oc=document.getElementById('s-oc').value;
  const bgOn=getSwState('s-bg-sw');
  const bgc=document.getElementById('s-bgc').value;
  const bga=parseInt(document.getElementById('s-bga').value)/100;
  const br=Math.round(parseInt(document.getElementById('s-br').value)*W/640);
  const shOn=getSwState('s-sh-sw');
  const sha=parseInt(document.getElementById('s-sha').value)/100;
  const pos=document.getElementById('s-pos').value;
  const mg=Math.round(parseInt(document.getElementById('s-mg').value)*W/640);
  ctx.font=`bold ${fsize}px ${font}`; ctx.textAlign='center'; ctx.textBaseline='middle';
  const maxW=W*0.88, words=text.split(' ');
  const lines=[]; let cur='';
  for(const w of words){const t=cur?cur+' '+w:w; if(ctx.measureText(t).width<=maxW){cur=t;}else{if(cur)lines.push(cur);cur=w;if(lines.length>=3)break;}}
  if(cur&&lines.length<3)lines.push(cur);
  const lh=fsize*1.35, padX=Math.round(14*W/640), padY=Math.round(8*W/640);
  let maxLw=0; lines.forEach(l=>{maxLw=Math.max(maxLw,ctx.measureText(l).width)});
  const bw=maxLw+padX*2, bh=lh*lines.length+padY*2;
  let cy; if(pos==='bottom')cy=H-mg-bh/2; else if(pos==='top')cy=mg+bh/2; else cy=H/2;
  const cx=W/2, bx=cx-bw/2, by=cy-bh/2;
  if(bgOn&&bga>0){ctx.fillStyle=hexToRgb(bgc,bga);const r=Math.min(br,bh/2);ctx.beginPath();ctx.moveTo(bx+r,by);ctx.lineTo(bx+bw-r,by);ctx.quadraticCurveTo(bx+bw,by,bx+bw,by+r);ctx.lineTo(bx+bw,by+bh-r);ctx.quadraticCurveTo(bx+bw,by+bh,bx+bw-r,by+bh);ctx.lineTo(bx+r,by+bh);ctx.quadraticCurveTo(bx,by+bh,bx,by+bh-r);ctx.lineTo(bx,by+r);ctx.quadraticCurveTo(bx,by,bx+r,by);ctx.closePath();ctx.fill();}
  lines.forEach((line,i)=>{const ly=by+padY+i*lh+lh/2;if(shOn&&sha>0){const so=Math.round(2*W/640);ctx.fillStyle=hexToRgb('#000000',sha);ctx.fillText(line,cx+so,ly+so);}if(ow>0){ctx.strokeStyle=oc;ctx.lineWidth=ow*1.5;ctx.lineJoin='round';ctx.strokeText(line,cx,ly);}ctx.fillStyle=color;ctx.fillText(line,cx,ly);});
}

function applyPreset(idx){
  selPreset=idx;
  document.querySelectorAll('.sub-preset').forEach((p,i)=>p.classList.toggle('sel',i===idx));
  const p=SUB_PRESETS[idx];
  document.getElementById('s-size').value=p.size; document.getElementById('s-size-v').textContent=p.size+'px';
  document.getElementById('s-color').value=p.color;
  document.getElementById('s-font').value=p.font;
  document.getElementById('s-ow').value=p.ow; document.getElementById('s-ow-v').textContent=p.ow+'px';
  document.getElementById('s-oc').value=p.oc;
  document.getElementById('s-bgc').value=p.bgc;
  document.getElementById('s-bga').value=p.bga; document.getElementById('s-bga-v').textContent=p.bga+'%';
  document.getElementById('s-br').value=p.br; document.getElementById('s-br-v').textContent=p.br+'px';
  document.getElementById('s-sha').value=p.sha; document.getElementById('s-sha-v').textContent=p.sha+'%';
  document.getElementById('s-pos').value=p.pos;
  document.getElementById('s-mg').value=p.mg; document.getElementById('s-mg-v').textContent=p.mg+'px';
  document.getElementById('s-bg-sw').classList.toggle('on',p.bg);
  document.getElementById('s-sh-sw').classList.toggle('on',p.sh);
  drawSubPreview();
}

function initPresets(){
  const grid=document.getElementById('sub-presets-grid');
  SUB_PRESETS.forEach((p,i)=>{
    const mc=document.createElement('canvas'); mc.width=80; mc.height=36;
    const ctx=mc.getContext('2d'); ctx.fillStyle='#111'; ctx.fillRect(0,0,80,36);
    ctx.font=`bold 11px ${p.font}`; ctx.textAlign='center'; ctx.textBaseline='middle';
    const txt='Aa';
    if(p.bg&&p.bga>0){ctx.fillStyle=hexToRgb(p.bgc,p.bga/100);const tw=ctx.measureText(txt).width+10,r=Math.min(p.br,8),bx=40-tw/2,by=18-10;ctx.beginPath();ctx.moveTo(bx+r,by);ctx.lineTo(bx+tw-r,by);ctx.quadraticCurveTo(bx+tw,by,bx+tw,by+r);ctx.lineTo(bx+tw,18);ctx.quadraticCurveTo(bx+tw,by+20,bx+tw-r,by+20);ctx.lineTo(bx+r,by+20);ctx.quadraticCurveTo(bx,by+20,bx,18);ctx.lineTo(bx,by+r);ctx.quadraticCurveTo(bx,by,bx+r,by);ctx.closePath();ctx.fill();}
    if(p.ow>0){ctx.strokeStyle=p.oc;ctx.lineWidth=p.ow;ctx.strokeText(txt,40,18);}
    ctx.fillStyle=p.color;ctx.fillText(txt,40,18);
    const el=document.createElement('div');
    el.className='sub-preset'+(i===0?' sel':'');
    el.onclick=()=>applyPreset(i);
    el.innerHTML=`<div class="sub-preset-prev"><img src="${mc.toDataURL()}" width="80" height="36"/></div><div class="sub-preset-name">${p.name}</div>`;
    grid.appendChild(el);
  });
}

function switchSubTab(name,el){
  document.querySelectorAll('.sub-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.sub-tab-panel').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('subtab-'+name).classList.add('active');
  if(name==='preview')setTimeout(drawSubPreview,50);
}

// ═══════════════════════════════════════════════════════
//  WORKFLOW STEPS
// ═══════════════════════════════════════════════════════
function goToStep(n){
  STATE.currentStep=n;
  document.querySelectorAll('.wsec').forEach((s,i)=>{
    s.classList.remove('active','done','locked');
    if(i+1<n){s.classList.add('done');s.querySelector('.wsec-num').textContent='✓';}
    else if(i+1===n){s.classList.add('active');s.querySelector('.wsec-num').textContent=i+1;}
    else{s.classList.add('locked');s.querySelector('.wsec-num').textContent=i+1;}
  });
  for(let i=1;i<=4;i++){
    const dot=document.getElementById(`sd-${i}`),wrap=document.getElementById(`sdw-${i}`);
    dot.className='step-dot';wrap.className='step-dot-wrap';
    if(i<n){dot.classList.add('done');wrap.classList.add('done');dot.textContent='✓';}
    else if(i===n){dot.classList.add('active');wrap.classList.add('active');dot.textContent=i;}
    else{dot.textContent=i;}
  }
  for(let i=1;i<=3;i++)document.getElementById(`sc-${i}-${i+1}`).classList.toggle('done',i<n);
}

// ═══════════════════════════════════════════════════════
//  LOG + PROGRESS
// ═══════════════════════════════════════════════════════
function log(msg,t=''){
  const el=document.getElementById('log-monitor');
  const ts=new Date().toLocaleTimeString('fr-FR');
  el.innerHTML+=`<span class="${t?'ll-'+t:''}">[${ts}] ${msg}\n</span>`;
  el.scrollTop=el.scrollHeight;
}
function clearLog(){document.getElementById('log-monitor').innerHTML='';}
function setProgress(label,pct,state='active'){
  document.getElementById('progress-label').textContent=label;
  document.getElementById('progress-pct').textContent=pct>0?pct+'%':'';
  document.getElementById('progress-bar').style.width=pct+'%';
  const dot=document.getElementById('progress-dot');
  dot.className='dot';
  if(state==='active')dot.classList.add('pulse');
  else if(state==='done')dot.classList.add('done');
  else if(state==='error')dot.classList.add('error');
}
function msToTC(ms){const s=Math.floor(ms/1000);return `${String(Math.floor(s/60)).padStart(2,'0')}:${String(s%60).padStart(2,'0')}`;}
async function apiPost(url,data){
  const r=await fetch(url,{method:'POST',headers:{'Content-Type':'application/json','X-CSRFToken':CSRF},body:JSON.stringify(data)});
  return r.json();
}

// ═══════════════════════════════════════════════════════
//  REPRISE DE PROJET — LOGIQUE AMÉLIORÉE
// ═══════════════════════════════════════════════════════
const STEP_LABELS = {
  'pending':      { step: 1, label: 'Vidéo chargée — lancez la transcription',       desc: 'Étape 2 : Transcrire' },
  'extracting':   { step: 2, label: 'Extraction audio en cours…',                    desc: 'Étape 2 : Transcrire' },
  'transcribing': { step: 2, label: 'Transcription en cours…',                       desc: 'Étape 2 : Transcrire' },
  'transcribed':  { step: 3, label: 'Transcription terminée — corrigez le script',   desc: 'Étape 3 : Générer la voix' },
  'synthesizing': { step: 3, label: 'Synthèse vocale en cours…',                     desc: 'Étape 3 : Générer la voix' },
  'done':         { step: 4, label: 'Voix générée — assemblez la vidéo',             desc: 'Étape 4 : Exporter' },
  'error':        { step: 1, label: 'Erreur — relancez depuis le début ou continuez','desc': 'Vérifiez le journal' },
};

function showResumeBanner(jobStatus, jobStep) {
  const banner = document.getElementById('resume-banner');
  const info   = STEP_LABELS[jobStatus] || STEP_LABELS['pending'];
  document.getElementById('resume-banner-text').textContent = `Reprise — ${info.label}`;
  document.getElementById('resume-banner-step').textContent = info.desc || '';
  banner.classList.add('show');
}

async function resumeProject(jobId, jobStatus) {
  log(`🔄 Reprise du projet (statut : ${jobStatus})…`, 'info');

  // Toujours recharger les segments
  try {
    const segsData = await (await fetch(`/api/jobs/${jobId}/segments/`)).json();
    if (segsData.length) {
      STATE.segments = segsData.map(s => ({
        id: s.id, index: s.index,
        start: s.start_ms, end: s.end_ms,
        start_ms: s.start_ms, end_ms: s.end_ms,
        text: s.text,
      }));
      renderScript(STATE.segments);
      document.getElementById('seg-count').textContent = `— ${STATE.segments.length} segments`;
      document.getElementById('btn-save-script').style.display = 'flex';
      if (segsData[0]) {
        document.getElementById('sub-preview-text').value = segsData[0].text || '';
        drawSubPreview();
      }
      log(`✅ ${STATE.segments.length} segments rechargés.`, 'info');
    }
  } catch(e) { log('⚠️ Impossible de charger les segments.', 'warn'); }

  // Activer les bons boutons selon le statut
  switch(jobStatus) {
    case 'pending':
      goToStep(1);
      document.getElementById('btn-transcribe').disabled = false;
      setProgress('Vidéo chargée — lancez la transcription', 5, 'done');
      break;

    case 'extracting':
    case 'transcribing':
      goToStep(2);
      setProgress('Transcription en cours…', 40);
      poll(jobId); // relancer le polling
      break;

    case 'transcribed':
      goToStep(3);
      document.getElementById('btn-transcribe').disabled = false;
      document.getElementById('btn-tts').disabled = false;
      setProgress('Transcription terminée — corrigez le script puis générez la voix', 100, 'done');
      break;

    case 'synthesizing':
      goToStep(3);
      setProgress('Synthèse vocale en cours…', 60);
      poll(jobId);
      break;

    case 'done':
      goToStep(4);
      document.getElementById('btn-transcribe').disabled = false;
      document.getElementById('btn-tts').disabled = false;
      document.getElementById('btn-export').disabled = false;

      // Vérifier si la vidéo finale existe
      const finalUrl = document.getElementById('final-url').value;
      if (finalUrl) {
        STATE.isFinalVideo = true;
        showFinalVideo(finalUrl);
        setProgress('Vidéo finale disponible — vous pouvez télécharger', 100, 'done');
      } else {
        setProgress('Voix générée — vous pouvez assembler la vidéo finale', 100, 'done');
      }
      break;

    case 'error':
      goToStep(1);
      document.getElementById('btn-transcribe').disabled = false;
      if (STATE.segments.length) {
        document.getElementById('btn-tts').disabled = false;
        goToStep(3);
      }
      setProgress('Erreur précédente — reprenez depuis l\'étape disponible', 0, 'error');
      break;

    default:
      goToStep(1);
  }

  showResumeBanner(jobStatus);
}

// ═══════════════════════════════════════════════════════
//  UPLOAD
// ═══════════════════════════════════════════════════════
const zone=document.getElementById('upload-zone'), fin=document.getElementById('file-input');
zone.addEventListener('dragover',e=>{e.preventDefault();zone.classList.add('dragover')});
zone.addEventListener('dragleave',()=>zone.classList.remove('dragover'));
zone.addEventListener('drop',e=>{e.preventDefault();zone.classList.remove('dragover');if(e.dataTransfer.files[0])pick(e.dataTransfer.files[0])});
fin.addEventListener('change',()=>{if(fin.files[0])pick(fin.files[0])});

function pick(file){
  STATE.uploadedFile=file;
  document.getElementById('upload-filename').textContent='📄 '+file.name;
  const v=document.getElementById('video-player');
  v.src=URL.createObjectURL(file); v.style.display='block';
  document.getElementById('video-placeholder').style.display='none';
  document.getElementById('btn-transcribe').disabled=false;
  document.getElementById('wsec-2').classList.remove('locked');
  document.getElementById('wsec-2').classList.add('active');
  setProgress('Vidéo chargée — lancez la transcription',5,'done');
  log(`Vidéo : ${file.name} (${(file.size/1048576).toFixed(1)} Mo)`);
  // Masquer le bandeau de reprise si on importe une nouvelle vidéo
  document.getElementById('resume-banner').classList.remove('show');
}

// ═══════════════════════════════════════════════════════
//  TRANSCRIPTION
// ═══════════════════════════════════════════════════════
document.getElementById('btn-transcribe').addEventListener('click', async()=>{
  const pid=document.getElementById('select-project').value;
  if(!pid){log('⚠️ Sélectionnez un projet.','warn');return;}
  if(!STATE.uploadedFile&&!STATE.jobId){log('⚠️ Aucune vidéo sélectionnée.','warn');return;}
  document.getElementById('btn-transcribe').disabled=true;
  goToStep(2); setProgress('Envoi de la vidéo…',8);

  // Si on relance la transcription sur un job existant avec un nouveau fichier
  if(STATE.uploadedFile){
    const fd=new FormData();
    fd.append('video_file',STATE.uploadedFile);
    fd.append('project_id',pid);
    fd.append('stt_engine','faster_whisper');
    fd.append('tts_engine',document.getElementById('select-tts').value);
    fd.append('language',document.getElementById('select-lang').value);
    let up;
    try{
      const r=await fetch('/api/jobs/',{method:'POST',headers:{'X-CSRFToken':CSRF},body:fd});
      up=await r.json();
    }catch(e){log('❌ Erreur envoi : '+e.message,'err');document.getElementById('btn-transcribe').disabled=false;return;}
    if(!up.id){log('❌ Upload échoué : '+JSON.stringify(up),'err');document.getElementById('btn-transcribe').disabled=false;return;}
    STATE.jobId=up.id;
  }

  log('Transcription démarrée…'); setProgress('Transcription en cours…',20);
  connectWS(STATE.jobId);
  const tr=await apiPost(`/api/jobs/${STATE.jobId}/transcribe/`,{
    stt_engine:'faster_whisper',
    language:document.getElementById('select-lang').value,
  });
  if(tr.task_id){if(!STATE.ws||STATE.ws.readyState!==WebSocket.OPEN)poll(STATE.jobId);}
  else{log('❌ '+JSON.stringify(tr),'err');document.getElementById('btn-transcribe').disabled=false;}
});

// ═══════════════════════════════════════════════════════
//  SAUVEGARDE + REDÉCOUPAGE
// ═══════════════════════════════════════════════════════
async function saveScript(){
  if(!STATE.jobId)return;
  const btn=document.getElementById('btn-save-script');
  btn.disabled=true;
  const editedSegments=[];
  document.querySelectorAll('.seg-txt').forEach(r=>{
    const idx=parseInt(r.dataset.index);
    const seg=STATE.segments[idx];
    if(!seg)return;
    editedSegments.push({id:seg.id,index:seg.index!==undefined?seg.index:idx,start_ms:seg.start_ms||seg.start||0,end_ms:seg.end_ms||seg.end||0,text:r.textContent.trim()});
  });
  log(`💾 Sauvegarde + redécoupage de ${editedSegments.length} segments…`,'info');
  try{
    const res=await apiPost(`/api/jobs/${STATE.jobId}/split_segments/`,{segments:editedSegments});
    if(res.segments&&res.segments.length){
      STATE.segments=res.segments.map(s=>({id:s.id,index:s.index,start:s.start_ms,end:s.end_ms,start_ms:s.start_ms,end_ms:s.end_ms,text:s.text}));
      renderScript(STATE.segments);
      document.getElementById('seg-count').textContent=`— ${STATE.segments.length} segments`;
      const delta=res.new_count-res.original_count;
      log(delta>0?`✅ ${res.original_count} segments → ${res.new_count} après découpage.`:`✅ ${res.new_count} segments sauvegardés.`,'info');
      showRecalcBadge();
      document.querySelectorAll('.seg-row').forEach(r=>{r.classList.add('tc-updated');setTimeout(()=>r.classList.remove('tc-updated'),2000)});
    }else{log('⚠️ Réponse inattendue : '+JSON.stringify(res),'warn');}
  }catch(e){log('❌ Erreur split_segments : '+e.message,'err');}
  btn.disabled=false;
  btn.innerHTML=`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>Sauvegarder`;
}
function showRecalcBadge(){const b=document.getElementById('recalc-badge');b.classList.add('show');setTimeout(()=>b.classList.remove('show'),3000);}

// ═══════════════════════════════════════════════════════
//  SYNTHÈSE
// ═══════════════════════════════════════════════════════
document.getElementById('btn-tts').addEventListener('click',async()=>{
  if(!STATE.jobId||!STATE.segments.length){log('⚠️ Transcription requise.','warn');return;}
  document.getElementById('btn-tts').disabled=true;
  goToStep(3); setProgress('Génération de la voix off…',10);
  const engine=document.getElementById('select-tts').value;
  const voice=STATE.selectedVoice;
  log(`🎙️ Voix "${voice}" via ${engine}…`);
  const r=await apiPost(`/api/jobs/${STATE.jobId}/synthesize/`,{
    tts_engine:engine,
    voice:voice,
    language:document.getElementById('select-lang').value,
  });
  if(r.task_id)poll(STATE.jobId);
  else{log('❌ '+JSON.stringify(r),'err');document.getElementById('btn-tts').disabled=false;}
});

// ═══════════════════════════════════════════════════════
//  EXPORT
// ═══════════════════════════════════════════════════════
document.getElementById('btn-export').addEventListener('click',async()=>{
  if(!STATE.jobId){log('⚠️ Aucun job actif.','warn');return;}
  document.getElementById('btn-export').disabled=true;
  STATE.isFinalVideo=false; STATE.prevExportStatus=null;
  goToStep(4); setProgress('Démarrage du montage…',5);
  log('Assemblage de la vidéo finale…');
  const r=await apiPost(`/api/jobs/${STATE.jobId}/export/`,{subtitle_style:getSubStyle()});
  if(r.task_id){log('Export démarré…','info');pollExport(STATE.jobId);}
  else{log('❌ '+JSON.stringify(r),'err');document.getElementById('btn-export').disabled=false;}
});

function pollExport(jobId){
  const steps=['Découpage des segments…','Synchronisation image/voix…','Assemblage vidéo…','Sous-titres ASS…','Encodage final…'];
  let pct=5,stepIdx=0;
  const iv=setInterval(async()=>{
    pct=Math.min(pct+2,90); setProgress(steps[Math.min(stepIdx,steps.length-1)],pct); stepIdx++;
    try{
      const job=await(await fetch(`/api/jobs/${jobId}/`)).json();
      if(STATE.prevExportStatus!==null&&STATE.prevExportStatus!=='done'&&job.status==='done'){
        clearInterval(iv); setProgress('Vérification du fichier…',92);
        const url=`/media/exports/${jobId}/final.mp4`;
        const ok=await waitForFile(url);
        if(ok){STATE.isFinalVideo=true;setProgress('Vidéo finale prête !',100,'done');showFinalVideo(url);}
        else{setProgress('Délai dépassé — réessayez',0,'error');}
        document.getElementById('btn-export').disabled=false;
      }
      if(job.status==='error'){clearInterval(iv);setProgress("Erreur lors de l'assemblage",0,'error');log('❌ '+(job.error_message||'Erreur inconnue'),'err');document.getElementById('btn-export').disabled=false;}
      STATE.prevExportStatus=job.status;
    }catch(e){}
  },3000);
}

async function waitForFile(url,maxAttempts=60,delayMs=5000){
  for(let i=0;i<maxAttempts;i++){
    try{const r=await fetch(url,{method:'HEAD'});if(r.ok){const size=parseInt(r.headers.get('content-length')||'0');if(size>1000000){log(`✅ Fichier prêt (${(size/1024/1024).toFixed(1)} Mo)`,'info');return true;}setProgress(`Encodage en cours… ${size>0?(size/1024).toFixed(0)+' Ko':' démarrage'}`,93);}}catch(e){}
    await new Promise(res=>setTimeout(res,delayMs));
  }
  return false;
}

function showFinalVideo(url){
  const v=document.getElementById('video-player');
  v.pause();v.removeAttribute('src');v.load();
  setTimeout(()=>{
    v.src=url+'?t='+Date.now(); v.style.display='block';
    document.getElementById('video-placeholder').style.display='none';
    document.getElementById('hud-mode').textContent='✓ VIDÉO FINALE';
    document.getElementById('hud-mode').style.color='#34D399';
    const dl=document.getElementById('btn-download');
    dl.href=url; dl.style.display='flex';
    v.play().catch(()=>{});
    log('✅ Vidéo finale chargée — prévisualisez puis téléchargez.','info');
  },800);
}

// ═══════════════════════════════════════════════════════
//  WEBSOCKET
// ═══════════════════════════════════════════════════════
function connectWS(jid){
  if(STATE.ws)STATE.ws.close();
  const proto=location.protocol==='https:'?'wss':'ws';
  STATE.ws=new WebSocket(`${proto}://${location.host}/ws/job/${jid}/`);
  const dot=document.getElementById('ws-dot'),lbl=document.getElementById('ws-status');
  STATE.ws.onopen=()=>{dot.className='ws-dot connected';lbl.textContent='Connecté'};
  STATE.ws.onclose=()=>{dot.className='ws-dot';lbl.textContent='Déconnecté'};
  STATE.ws.onerror=()=>{dot.className='ws-dot error';lbl.textContent='Erreur'};
  STATE.ws.onmessage=e=>onWS(JSON.parse(e.data));
}

function onWS(msg){
  switch(msg.type){
    case 'status':   log(msg.message); break;
    case 'progress': setProgress(msg.label||'…',msg.percent||0); break;
    case 'waveform': STATE.waveform=msg.data; drawWave(msg.data); break;
    case 'segments':
      STATE.segments=msg.data; renderScript(msg.data);
      setProgress('Transcription terminée — corrigez puis sauvegardez',100,'done');
      goToStep(3);
      document.getElementById('btn-tts').disabled=false;
      document.getElementById('btn-save-script').style.display='flex';
      if(msg.data.length)document.getElementById('sub-preview-text').value=msg.data[0].text||'';
      drawSubPreview();
      log(`✅ ${msg.data.length} segments transcrits.`); break;
    case 'tts_progress':
      setProgress(`Génération voix — segment ${msg.current}/${msg.total}…`,Math.round(msg.current/msg.total*100)); break;
    case 'tts_done':
      log(`✅ ${msg.nb_ok}/${msg.nb_total} segments vocaux générés.`);
      setProgress('Voix générée — vous pouvez assembler la vidéo',100,'done');
      goToStep(4);
      document.getElementById('btn-tts').disabled=false;
      document.getElementById('btn-export').disabled=false; break;
    case 'export_done':
      (async()=>{
        if(STATE.isFinalVideo)return;
        setProgress('Vérification du fichier…',95);
        const url=msg.download_url;
        let ready=false;
        for(let i=0;i<12;i++){
          try{const r=await fetch(url,{method:'HEAD'});if(r.ok&&parseInt(r.headers.get('content-length')||'0')>1000000){ready=true;break;}}catch(e){}
          await new Promise(res=>setTimeout(res,3000));
        }
        if(ready){STATE.isFinalVideo=true;setProgress('Vidéo finale prête !',100,'done');showFinalVideo(url);}
        document.getElementById('btn-export').disabled=false;
      })(); break;
    case 'error':
      log('❌ '+msg.message,'err'); setProgress('Erreur',0,'error');
      document.getElementById('btn-transcribe').disabled=false;
      document.getElementById('btn-tts').disabled=false; break;
  }
}

// ═══════════════════════════════════════════════════════
//  POLLING
// ═══════════════════════════════════════════════════════
function poll(jid){
  if(STATE.pollInterval)clearInterval(STATE.pollInterval);
  STATE.pollInterval=setInterval(async()=>{
    try{
      const job=await(await fetch(`/api/jobs/${jid}/`)).json();
      const s=job.status;
      const labels={extracting:['Extraction audio…',30],transcribing:['Transcription…',60],transcribed:['Transcription terminée',100],synthesizing:['Synthèse vocale…',70],done:['Terminé',100],error:['Erreur',0]};
      if(labels[s])setProgress(labels[s][0],labels[s][1],s==='error'?'error':s==='done'?'done':'active');
      if(s==='transcribed'&&!STATE.segments.length){
        const sd=await(await fetch(`/api/jobs/${jid}/segments/`)).json();
        if(sd.length){
          STATE.segments=sd.map(x=>({id:x.id,index:x.index,start:x.start_ms,end:x.end_ms,start_ms:x.start_ms,end_ms:x.end_ms,text:x.text}));
          renderScript(STATE.segments); goToStep(3);
          document.getElementById('btn-tts').disabled=false;
          document.getElementById('btn-transcribe').disabled=false;
          document.getElementById('btn-save-script').style.display='flex';
          document.getElementById('sub-preview-text').value=sd[0].text||'';
          drawSubPreview();
          setProgress('Transcription terminée — corrigez puis sauvegardez',100,'done');
          clearInterval(STATE.pollInterval); STATE.pollInterval=null;
        }
      }
      if(s==='done'){
        clearInterval(STATE.pollInterval); STATE.pollInterval=null;
        document.getElementById('btn-tts').disabled=false;
        document.getElementById('btn-export').disabled=false;
        document.getElementById('btn-transcribe').disabled=false;
        goToStep(4);
        if(!STATE.segments.length){
          const sd=await(await fetch(`/api/jobs/${jid}/segments/`)).json();
          if(sd.length){STATE.segments=sd.map(x=>({id:x.id,index:x.index,start:x.start_ms,end:x.end_ms,start_ms:x.start_ms,end_ms:x.end_ms,text:x.text}));renderScript(STATE.segments);document.getElementById('btn-save-script').style.display='flex';}
        }
      }
      if(s==='error'){clearInterval(STATE.pollInterval);STATE.pollInterval=null;log('❌ '+(job.error_message||'Erreur'),'err');document.getElementById('btn-transcribe').disabled=false;document.getElementById('btn-tts').disabled=false;}
    }catch(e){}
  },2500);
}

// ═══════════════════════════════════════════════════════
//  WAVEFORM
// ═══════════════════════════════════════════════════════
function drawWave(data){
  const c=document.getElementById('waveform-canvas');
  const ctx=c.getContext('2d');
  const W=c.offsetWidth,H=c.offsetHeight;
  c.width=W;c.height=H;
  ctx.fillStyle='#07090E';ctx.fillRect(0,0,W,H);
  if(!data||!data.length)return;
  const g=ctx.createLinearGradient(0,0,W,0);
  g.addColorStop(0,'rgba(59,130,246,.5)');g.addColorStop(.5,'rgba(6,182,212,.6)');g.addColorStop(1,'rgba(59,130,246,.5)');
  ctx.strokeStyle=g;ctx.lineWidth=1;
  const step=W/data.length;
  for(let i=0;i<data.length;i++){const x=i*step,a=data[i]*(H/2);ctx.beginPath();ctx.moveTo(x,H/2-a);ctx.lineTo(x,H/2+a);ctx.stroke();}
}
function drawHead(){
  if(!STATE.waveform.length)return;
  const c=document.getElementById('waveform-canvas'),v=document.getElementById('video-player');
  if(!v.duration)return;
  drawWave(STATE.waveform);
  const ctx=c.getContext('2d');
  const x=(v.currentTime/v.duration)*c.width;
  ctx.strokeStyle='rgba(239,68,68,.8)';ctx.lineWidth=1.5;
  ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,c.height);ctx.stroke();
}

// ═══════════════════════════════════════════════════════
//  SCRIPT EDITOR
// ═══════════════════════════════════════════════════════
function renderScript(segs){
  const ed=document.getElementById('script-editor');
  ed.innerHTML='';
  document.getElementById('seg-count').textContent=`— ${segs.length} segments`;
  segs.forEach((seg,i)=>{
    const r=document.createElement('div');
    r.className='seg-row'; r.dataset.index=i;
    r.innerHTML=`<span class="seg-tc">${msToTC(seg.start||seg.start_ms)}</span><div class="seg-txt" contenteditable="true" data-index="${i}">${seg.text}</div>`;
    r.addEventListener('click',()=>{
      document.getElementById('video-player').currentTime=(seg.start||seg.start_ms)/1000;
      hl(i);
      document.getElementById('sub-preview-text').value=seg.text;
      drawSubPreview();
    });
    ed.appendChild(r);
  });
}
function hl(idx){
  document.querySelectorAll('.seg-row').forEach(r=>r.classList.remove('active'));
  const r=document.querySelector(`.seg-row[data-index="${idx}"]`);
  if(r){r.classList.add('active');r.scrollIntoView({block:'nearest',behavior:'smooth'});}
}

// ═══════════════════════════════════════════════════════
//  TRANSPORT
// ═══════════════════════════════════════════════════════
const vid=document.getElementById('video-player'),sb=document.getElementById('seek-bar');
function togglePlay(){
  const ico=document.getElementById('play-icon');
  if(vid.paused){vid.play();ico.innerHTML='<rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>';}
  else{vid.pause();ico.innerHTML='<polygon points="5 3 19 12 5 21"/>';}
}
vid.addEventListener('timeupdate',()=>{
  if(!vid.duration)return;
  sb.value=(vid.currentTime/vid.duration)*100;
  document.getElementById('time-display').textContent=`${msToTC(vid.currentTime*1000)} / ${msToTC(vid.duration*1000)}`;
  const ov=document.getElementById('subtitle-overlay');
  if(STATE.isFinalVideo){ov.style.display='none';}
  else{const ms=vid.currentTime*1000;const seg=STATE.segments.find(s=>ms>=(s.start||s.start_ms)&&ms<=(s.end||s.end_ms));if(seg){ov.textContent=seg.text;ov.style.display='block';hl(STATE.segments.indexOf(seg));}else{ov.style.display='none';}}
  drawHead();
});
vid.addEventListener('loadedmetadata',()=>{
  const el=document.getElementById('hud-res');
  el.textContent=`${vid.videoWidth}×${vid.videoHeight}`;
  el.style.display='block';
});
sb.addEventListener('input',()=>{if(vid.duration)vid.currentTime=(sb.value/100)*vid.duration;});

// ═══════════════════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════════════════
window.addEventListener('load',()=>{
  // Construire les grilles de voix
  buildVoiceGrids();
  // Appliquer le moteur TTS sauvegardé
  const savedEngine = document.getElementById('current-job-tts').value || 'elevenlabs';
  document.getElementById('select-tts').value = savedEngine;
  onTtsEngineChange();
  // Appliquer la voix sauvegardée
  const savedVoice = document.getElementById('current-job-voice').value || 'narrateur_pro';
  selectVoice(savedVoice);

  initPresets();
  drawSubPreview();

  if(STATE.jobId){
    connectWS(STATE.jobId);

    // Charger la vidéo (finale si dispo, sinon source)
    const videoUrl=document.getElementById('video-url').value;
    const finalUrl=document.getElementById('final-url').value;

    if(finalUrl){
      STATE.isFinalVideo=true;
      const v=document.getElementById('video-player');
      v.src=finalUrl+'?t='+Date.now(); v.style.display='block';
      document.getElementById('video-placeholder').style.display='none';
      document.getElementById('hud-mode').textContent='✓ VIDÉO FINALE';
      document.getElementById('hud-mode').style.color='#34D399';
      document.getElementById('btn-download').href=finalUrl;
      document.getElementById('btn-download').style.display='flex';
      const fname=finalUrl.split('/').pop().split('?')[0];
      document.getElementById('upload-filename').textContent='🎬 '+fname;
    }else if(videoUrl){
      const v=document.getElementById('video-player');
      v.src=videoUrl; v.style.display='block';
      document.getElementById('video-placeholder').style.display='none';
      const fname=videoUrl.split('/').pop().split('?')[0];
      document.getElementById('upload-filename').textContent='📄 '+fname;
    }

    // ── REPRISE DE PROJET ──────────────────────────
    const jobStatus = STATE.jobStatus;
    resumeProject(STATE.jobId, jobStatus);
  }

  window.addEventListener('resize',drawSubPreview);
});
</script>
{% endblock %}