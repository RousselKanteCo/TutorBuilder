# ══════════════════════════════════════════════════════════════
#  TutoBuilder Vision — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs
# ══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────
#  DJANGO
# ─────────────────────────────────────────
DJANGO_SECRET_KEY=changez-cette-cle-en-production-avec-openssl-rand-base64-50
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.development

# ─────────────────────────────────────────
#  BASE DE DONNÉES (PostgreSQL)
# ─────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=tutobuilder
DB_USER=tutobuilder
DB_PASSWORD=changeme_in_production
DB_HOST=localhost
DB_PORT=5432

# ─────────────────────────────────────────
#  REDIS (Celery broker + Django Channels)
# ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─────────────────────────────────────────
#  STOCKAGE FICHIERS (MinIO / S3)
# ─────────────────────────────────────────
USE_S3=False
AWS_ACCESS_KEY_ID=monument
AWS_SECRET_ACCESS_KEY=changeme_in_production
AWS_STORAGE_BUCKET_NAME=tutobuilder
AWS_S3_ENDPOINT_URL=http://localhost:9000

# ─────────────────────────────────────────
#  API EXTERNES
# ─────────────────────────────────────────
ELEVENLABS_API_KEY=

# ─────────────────────────────────────────
#  CHEMINS FICHIERS
# ─────────────────────────────────────────
MEDIA_ROOT=media
OUTPUTS_ROOT=outputs
MODELS_ROOT=models

# ─────────────────────────────────────────
#  LIMITES UPLOAD
# ─────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500
