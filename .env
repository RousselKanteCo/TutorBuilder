# ══════════════════════════════════════════════════════════════
#  TutoBuilder Vision — Variables d'environnement
# ══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────
#  DJANGO
# ─────────────────────────────────────────
DJANGO_SECRET_KEY=monument-v8-graphelya-secret-key-tutobuilder-2025-xK9mP2nQ
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.development

# ─────────────────────────────────────────
#  BASE DE DONNÉES
#  → SQLite en dev Windows (pas besoin de PostgreSQL)
# ─────────────────────────────────────────
DATABASE_URL=sqlite:///db_dev.sqlite3
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=tutobuilder
DB_USER=tutobuilder
DB_PASSWORD=changeme_in_production
DB_HOST=localhost
DB_PORT=5432

# ─────────────────────────────────────────
#  REDIS
#  → Laisser tel quel, utilisé seulement quand Celery tourne
# ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=True

# ─────────────────────────────────────────
#  STOCKAGE FICHIERS
#  → Valeurs tirées de docker-compose.yml
# ─────────────────────────────────────────
USE_S3=False
AWS_ACCESS_KEY_ID=monument
AWS_SECRET_ACCESS_KEY=changeme_in_production
AWS_STORAGE_BUCKET_NAME=tutobuilder
AWS_S3_ENDPOINT_URL=http://localhost:9000

# ─────────────────────────────────────────
#  API EXTERNES
#  → Votre clé ElevenLabs si vous en avez une
# ─────────────────────────────────────────
ELEVENLABS_API_KEY=sk_0770518c7a7c7fe59f74078cd4d61144059812e99a74a7eb

# ─────────────────────────────────────────
#  CHEMINS FICHIERS (tirés de docker-compose.yml)
# ─────────────────────────────────────────
MEDIA_ROOT=media
OUTPUTS_ROOT=outputs
MODELS_ROOT=models

# ─────────────────────────────────────────
#  LIMITES UPLOAD (tirés de server.py : MAX_FILE_SIZE = 500 Mo)
# ─────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500

DATABASE_URL=sqlite:///db_dev.sqlite3